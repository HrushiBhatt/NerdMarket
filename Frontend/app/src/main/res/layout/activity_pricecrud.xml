<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1F3A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price Listings"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Card ID: "
                android:textSize="20dp"
                android:textColor="#ffffff">
            </TextView>

            <EditText
                android:id="@+id/pricecrud_id"
                android:layout_width="wrap_content"
                android:textColor="#ffffff"
                android:layout_height="50dp"
                android:hint="                         ">
            </EditText>

            <Button
                android:id="@+id/pricecrud_findbyid"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Find"
                android:textColor="#0B1F3A"
                android:backgroundTint="#FFFFFF"
                />

        </LinearLayout>

        <TextView
            android:id="@+id/pricecrud_currentprice"
            android:text="Current Price: "
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_width="230sp"
            android:layout_height="30sp"/>

        <EditText
            android:id="@+id/pricecrud_changeprice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/pricecrud_update"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Update Price"
            android:textColor="#0B1F3A"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/pricecrud_create"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Create New Record"
            android:textColor="#0B1F3A"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/pricecrud_changeprice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="#FFFFFF"
            android:hint="Enter new price here"
            android:layout_marginBottom="30dp"/>


        <Button
            android:id="@+id/pricecrud_delete"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Delete Record"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B00020"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>